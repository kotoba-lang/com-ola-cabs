// Ola_cabs clean-room schema -> Datomic EAVT mapping
// Generated by deepen_actors.py (ADR 260607 deepening phase).

namespace ola_cabs {

    entity User {
        id: string @unique
        phone: string
        displayName: string
        kycStatus: string
        walletId: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Wallet {
        id: string @unique
        userId: string
        currency: string
        balance: float
        status: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Merchant {
        id: string @unique
        name: string
        category: string
        rating: float
        createdAt: datetime
        updatedAt: datetime
    }

    entity RideOrder {
        id: string @unique
        userId: string
        origin: string
        destination: string
        fare: float
        status: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity FoodOrder {
        id: string @unique
        userId: string
        merchantId: string
        total: float
        status: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Payment {
        id: string @unique
        userId: string
        amount: float
        currency: string
        method: string
        status: string
        createdAt: datetime
        updatedAt: datetime
    }

}

    // Auto-injected Cognitive Schema
    entity CognitiveRecord {
        id: string @unique
        originalPayload: string
        aiStatus: string
        aiInsights: json
        computedAt: datetime
    }
